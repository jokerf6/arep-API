model User {
  id       Int     @id @default(autoincrement())
  name     String
  email    String
  phone    String
  password String
  verified Boolean @default(false)
  active   Boolean @default(true)
  deviceId String? @unique @map("device_id")
  image    String  @default("uploads/default.png")

  // default columns
  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")

  // direct relations
  Role    Role   @relation(fields: [roleKey], references: [roleKey], onDelete: Cascade)
  roleKey String @map("role_key")

  // relations
  OTPs          OTP[]
  Sessions      Session[]
  Notifications Notification[]
  Details       Details?
  Address       Address?

  @@unique([email, roleKey])
  @@unique([phone, roleKey])
  @@index([phone, roleKey])
  @@index([email, roleKey])
  @@map("users")
}

model Test {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")
}

model Details {
  userId Int  @id @unique @map("user_id")
  User   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  wallet Float?   @default(0.0)
  points Float?   @default(0.0)
  male   Boolean?

  @@map("details")
}

model Address {
  userId Int  @id @unique @map("user_id")
  User   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  title String @map("title")
  lat   Float  @map("lat")
  lng   Float  @map("lng")

  @@map("addresses")
}
