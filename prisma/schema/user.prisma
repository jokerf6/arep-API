model User {
  id        Int       @id @default(autoincrement())
  name      String
  email     String?
  phone     String?
  password  String?
  birthDate DateTime? @map("birth_date")
  verified  Boolean   @default(false)
  active    Boolean   @default(true)
  sex       Boolean?
  deviceId  String?   @unique @map("device_id")
  image     String    @default("uploads/default.png")
  // default columns
  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")

  // direct relations
  Role    Role   @relation(fields: [roleKey], references: [roleKey], onDelete: Cascade)
  roleKey String @map("role_key")

  // relations
  OTPs          OTP[]
  Sessions      Session[]
  Notifications Notification[]
  Devices       Devices[]
  UserCoupons   UserCoupons[]
  Fund          Fund[]
  Transaction   Transaction[]

  Address Address?

  @@unique([email])
  @@unique([phone])
  @@index([phone])
  @@index([email])
  @@map("users")
}

model Address {
  id Int @id @default(autoincrement())

  userId Int  @unique @map("user_id")
  User   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")

  street1 String @map("street_1") @db.Text
  street2 String @map("street_2") @db.Text
  city    String
  state   String
  country String
  zipCode String @map("zip_code")

  @@map("addresses")
}
