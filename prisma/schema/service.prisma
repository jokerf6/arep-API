model Service {
    id                 Int                 @id @default(autoincrement())
    name               Json
    description        Json
    image              String
    durationMinutes    Int                 @map("duration_minutes")
    availableFrom      DateTime            @map("available_from") @db.Time()
    availableTo        DateTime            @map("available_to") @db.Time()
    price              Float
    priceAfterDiscount Float               @map("price_after_discount")
    discount           Float
    discountType       DiscountServiceType @default(NONE) @map("discount_type")
    status             ServiceStatus       @default(PENDING)

    // statistics
    totalOrders     Int      @default(0) @map("total_orders")
    totalAmountSold Int      @default(0) @map("total_amount_sold")
    rating          Float      @default(0)
    review          Int      @default(0)
    bestRated       Boolean? @default(false) @map("best_rated")
    mostSeller      Boolean? @default(false) @map("most_seller")

    //default
    deletedAt DateTime? @map("deleted_at")
    createdAt DateTime  @default(now()) @map("created_at")

    // relations 
    storeId       Int @map("store_id")
    subCategoryId Int @map("sub_category_id")

    Store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
    SubCategory Category @relation(fields: [subCategoryId], references: [id], onDelete: Cascade)

    Favorites FavoriteService[]
    Variation Variation[]

  @@map("services")

    Order Order[]
    ServiceRating ServiceRating[]
}

model FavoriteService {
    serviceId  Int     @map("service_id")
    customerId Int     @map("customer_id")
    Service    Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
    Customer   User    @relation(fields: [customerId], references: [id], onDelete: Cascade)

    @@id([serviceId, customerId])
    @@index([serviceId, customerId])
    @@map("favorite_service")
}

model Variation {
    id          Int     @id @default(autoincrement())
    name        String
    required    Boolean @default(false)
    minQuantity Int?    @map("min_quantity")
    maxQuantity Int?    @map("max_quantity")
    single      Boolean @default(true)

    serviceId Int
    Service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

    deletedAt DateTime? @map("deleted_at")

    VariationOption VariationOption[]

  @@map("variations")
    OrderVariations OrderVariation[]
}

model VariationOption {
    id      Int     @id @default(autoincrement())
    name    String
    price   Float
    default Boolean @default(false)

    variationId Int       @map("variation_id")
    Variation   Variation @relation(fields: [variationId], references: [id], onDelete: Cascade)

    deletedAt DateTime? @map("deleted_at")

 @@map("variation_options")
    OrderVariationOptions OrderVariationOptions[]
}

enum ServiceStatus {
    PENDING
    ACTIVE
    INACTIVE
    REJECTED
}

enum DiscountServiceType {
    PERCENTAGE
    AMOUNT
    NONE
}
