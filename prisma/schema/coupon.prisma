model Coupon {
  id Int @id @default(autoincrement())

  // Normal Fields
  title            Json         @map("title")
  code             String       @unique
  type             CouponType
  discountType     DiscountType @map("discount_type")
  discountValue    Int          @map("discount_value")
  maxUsage         Int          @map("max_usage")
  usageCount       Int          @map("usage_count")
  minOrderAmount   Int          @map("min_order_amount")
  freeDelivery     Boolean      @map("free_delivery")
  active           Boolean      @default(true)
  startDate        DateTime     @map("start_date")
  endDate          DateTime     @map("end_date")
  minDiscountValue Int          @map("min_discount_value")
  maxDiscountValue Int          @map("max_discount_value")

  // Default Fields
  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")

  // Direct Relations
  UserCoupons  UserCoupons[]
  StoreCoupons StoreCoupons[]

  @@map("coupons")
}

model UserCoupons {
  id       Int    @id @default(autoincrement())
  Coupon   Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
  couponId Int    @map("coupon_id")

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int  @map("user_id")

  @@unique([couponId, userId])
  @@map("user_coupons")
}

model StoreCoupons {
  id       Int    @id @default(autoincrement())
  Coupon   Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
  couponId Int    @map("coupon_id")

  Store   Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  storeId Int   @map("store_id")

  @@unique([couponId, storeId])
  @@map("store_coupons")
}

enum CouponType {
  ALL_USERS
  ALL_STORES
  FIRST_ORDER
  USER_WISE
  STORE_WISE
  FREE_DELIVERY
}

enum DiscountType {
  AMOUNT
  PERCENTAGE
}
