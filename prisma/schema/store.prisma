model Store {

  id Int @id @default(autoincrement())

  // Normal Fields
  name              Json
  logo              String
  cover             String
  address           String
  lat               Float
  lng               Float
  rating            Float @default(0)
  review            Float @default(0)
  commission        Float @default(0)
  tax        Float @default(0)
  isStoreAccepted   Boolean @default(false)
  closed            Boolean @default(true)
  temporarilyClosed Boolean @map("temporarily_closed") @default(false)
  phone             String
  status            StoreStatus @default(NOT_VERIFIED)

  // Default Fields
  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")

  // Direct Relations
  Module   Module @relation(fields: [moduleId], references: [id])
  moduleId Int
  Plan   Plan? @relation(fields: [planId], references: [id])
  planId Int?

  City   City @relation(fields: [cityId], references: [id])
  cityId Int

  Banner Banner[] @relation(name: "BannerToStore")
  Favorites FavoriteStore[]
  Services Service[]
    StoreSchedule          StoreSchedule[]
  StoreCoupons StoreCoupons[]
  @@map("stores")
  User User[]
  Categories Category[] @relation("StoreCategory")
}

model StoreSchedule {
  id          Int      @id @default(autoincrement())
  storeId     Int      @map("store_id")
  openingTime DateTime @map("opening_time") @db.Time()
  closingTime DateTime @map("closing_time") @db.Time()
  day         Days
  Store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@map("store_schedule")
}


model FavoriteStore {
  storeId    Int      @map("store_id")
  customerId Int      @map("customer_id")
  Store      Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  Customer   User @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@id([storeId, customerId])
  @@index([storeId, customerId])
  @@map("favorite_store")
}

enum StoreStatus {
  ACTIVE
  BLOCKED
  NOT_VERIFIED
}
enum Days {
  SUNDAY
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
}