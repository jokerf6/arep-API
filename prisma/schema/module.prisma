model Module {
  id Int @id @default(autoincrement())

  // Normal Fields
  name        Json
  description Json
  image       String
  active      Boolean   @default(true)
  order       Int       @default(1)
  // Default Fields
  createdAt   DateTime  @default(now()) @map("created_at")
  deletedAt   DateTime? @map("deleted_at")

  // Direct Relations
  Category Category[] 
  stores Store[] 

  @@map("modules")

}
