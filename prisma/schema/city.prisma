model City {
  id        Int       @id @default(autoincrement())
  name      Json
  deletedAt DateTime? @map("deleted_at")

  @@map("city")
}

model Nationality {
  id        Int       @id @default(autoincrement())
  name      Json
  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")
  users     User[]

  @@map("nationalities")
}
